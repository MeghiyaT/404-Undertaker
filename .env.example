# Storacha is the current Web3.Storage-backed Filecoin upload provider.
# Do not put private keys or UCAN proofs in VITE_* variables; they are public in browser bundles.

# Optional. On first upload, Storacha sends a confirmation email for browser-agent authorization.
VITE_STORACHA_LOGIN_EMAIL=

# Optional. Use when the authorized browser agent has access to more than one space.
VITE_STORACHA_SPACE_DID=
